{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MongoDb": {
    "ConnectionString": "CHANGE_ME",
    "DatabaseName": "agripeweb"
  },
  "JwtSettings": {
    "secretkey": "CHANGE_ME",
    "issuer": "agripeweb.com",
    "audience": "https://agripeweb.com"
  },
  "OAuth": {
    "Google": {
      "ClientId": "CHANGE_ME",
      "ClientSecret": "CHANGE_ME",
      "AllowedRedirectUris": "http://localhost:4200/login/callback"
    }
  },
  "WeatherForecast": {
    "ForecastHorizonDays": 5,
    "RainThresholdMm": 5.0,
    "PrimarySource": "OpenMeteo",
    "FallbackSource": "OpenMeteo",
    "GoogleWeatherApiKey": "CHANGE_ME",
    "CacheDurationMinutes": 60
  },
  "AI": {
    "AnthropicApiKey": "CHANGE_ME",
    "Model": "claude-sonnet-4-6",
    "MaxTokens": 1024,
    "CacheDurationMinutes": 30
  }
}
