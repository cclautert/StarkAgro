# Copy to docker/.env and fill in real values.
# NEVER commit .env with real secrets.

# JWT
JWT_SECRET_KEY=CHANGE_ME_min_32_chars_random_string
JWT_ISSUER=agripeweb.com
JWT_AUDIENCE=https://agripeweb.com

# Google OAuth (https://console.cloud.google.com/ → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# MQTT broker credentials
# Generate password file: mosquitto_passwd -c docker/mosquitto/passwd <username>
# Then set matching values here.
MQTT_USERNAME=CHANGE_ME
MQTT_PASSWORD=CHANGE_ME
